      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-microgrid" },
          "query": "SELECT last(\"p_kw\") AS \"p_kw\" FROM \"asset_telemetry\" WHERE \"asset_type\" = 'wind' AND $timeFilter GROUP BY \"asset_id\"",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
